rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================================
    // Helper Functions
    // ============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // A simpler, safer isAdmin check
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "alonesourav310@gmail.com" ||
        request.auth.token.email == "stvnews2026@gmail.com" ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true)
      );
    }

    function isValidPost() {
      let data = request.resource.data;
      return (data.title is string || data.titleEn is string) && data.slug is string;
    }

    function isValidComment() {
      let data = request.resource.data;
      return data.postId is string && data.userId is string && data.comment is string;
    }

    // ============================================================
    // Posts Collection
    // ============================================================

    match /posts/{postId} {
      allow read: if true;
      allow create: if isAdmin() && isValidPost();
      allow delete: if isAdmin();

      // Allow authenticated users to update engagement counters
      // Allow engagement updates
      allow update: if isAdmin() || 
        request.resource.data.diff(resource.data).affectedKeys().hasAny(['likesCount', 'commentsCount', 'viewsCount', 'updatedAt']);

      match /likes/{userId} {
        allow read: if true;
        allow write: if isAuthenticated() && isOwner(userId);
      }
    }

    // ============================================================
    // Comments Collection
    // ============================================================

    match /comments/{commentId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidComment();
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());

      // Allow updating engagement counters (likes)
      allow update: if isAuthenticated() &&
        request.resource.data.diff(resource.data).affectedKeys().hasAny(['likesCount', 'updatedAt']) &&
        request.resource.data.userId == resource.data.userId;

      match /likes/{userId} {
        allow read: if true;
        allow write: if isAuthenticated() && isOwner(userId);
      }
    }

    // ============================================================
    // Users Collection
    // ============================================================

    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow create: if isAuthenticated() && isOwner(userId);
      allow update: if isAdmin() || (isAuthenticated() && isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isAdmin']));
      allow delete: if isAdmin();
    }
  }
}
